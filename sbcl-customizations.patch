diff -Naur sbcl.old/src/runtime/binaries.mk sbcl.new/src/runtime/binaries.mk
--- sbcl.old/src/runtime/binaries.mk	1969-12-31 17:00:00.000000000 -0700
+++ sbcl.new/src/runtime/binaries.mk	2026-03-23 17:46:17.693704049 -0600
@@ -0,0 +1,18 @@
+include sbcl.mk
+
+all: targets
+BINARIES=sbcl sbcl.extras
+targets: $(BINARIES)
+
+SLIBS=-Wl,--whole-archive $(WHOLE_ARCHIVES) -Wl,--no-whole-archive
+
+sbcl: $(LIBSBCL)
+	$(CC) -fno-pie -no-pie $(LINKFLAGS) -o $@ $(LIBSBCL) $(LIBS)
+
+sbcl.extras: $(LIBSBCL)
+	$(CC) -fno-pie -no-pie $(LINKFLAGS) -o $@ $(LIBSBCL) $(SLIBS) $(LIBS)
+
+clean:
+	$(RM) $(BINARIES)
+
+.PHONY: all targets
